{
  "manifest_version": 3,
  "name": "Linklog",
  "version": "1.0.3",
  "description": "Save links to your linkblog with one click, right-click, or keyboard shortcut",
  "permissions": ["activeTab", "storage", "contextMenus", "notifications"],
  "host_permissions": ["https://api.linklog.app/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "linklog@luther.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background/service-worker.js"],
    "type": "module"
  },
  "commands": {
    "save-current-page": {
      "suggested_key": {
        "default": "Alt+Shift+L",
        "mac": "Alt+Shift+L"
      },
      "description": "Save current page to Linkblog"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
